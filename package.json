{
  "name": "naval-war",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspace=packages/types && npm run build --workspace=server && npm run build --workspace=client",
    "build:types": "npm run build --workspace=packages/types"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
